<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }} · cli_izdat</title>
  <link rel="stylesheet" href="{{ '/css/styles.css' | url }}">
</head>
<body>
  <header>
    <p class="last-login">Last login: <ac>{{ null | renderDate }}</ac> on ttys000</p>
    <h1 class="post-figlet"><pre>{{ title | figlet(cover_font or "Slant") }}</pre></h1>
    <nav>
      <span class="nav-tilde">~</span><span class="nav-sep">/</span><a href="{{ '/' | url }}">home</a><span class="nav-sep">/</span><a href="{{ '/archive/' | url }}">archive</a><span class="nav-sep">/</span><span class="active">{{ title }}</span>
    </nav>
  </header>

  <main>
    <article class="slides">
      <section class="slide slide--cover">
        <p class="subtitle">{{ subtitle }}</p>
        <p class="topics">topics:
          {% for tag in tags %}
            <a href="{{ ('/archive/tag/' + tag + '/') | url }}">{{ tag }}</a>{% if not loop.last %} | {% endif %}
          {% endfor %}
        </p>
      </section>
      {{ content | safe }}
    </article>
  </main>

  <footer>
    <p>2026 Alég's Web Exercises</p>
  </footer>
  <script>
    if (new URL(location.href).searchParams.has("render")) {
      document.body.classList.add("render-mode");
    }
  </script>
</body>
</html>
